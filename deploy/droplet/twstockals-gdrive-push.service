[Unit]
Description=twstockals Google Drive push (reports -> Drive)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=brian
Group=brian
Environment=TWSTOCKALS_WORKSPACE=/home/brian/twstockals
Environment=TZ=Asia/Taipei
WorkingDirectory=/home/brian/twstockals
ExecStart=/bin/bash /home/brian/twstockals/deploy/droplet/gdrive_push_reports.sh
Nice=10

[Install]
WantedBy=multi-user.target
